# Kullanim:
#   cp .env.example .env
#   .env dosyasini duzenle (bu dosya git'e gitmez).
#
# SUPABASE_DB_PASSWORD = Supabase Dashboard > Project Settings > Database
#   alanindaki "Database password" (Reset ile yeni uretebilirsin).
#   Anon key, service_role veya WiFi sifresi DEGIL.
#
# Sifrede # $ " ' gibi karakterler varsa tum degeri tirnak icine al:
#   SUPABASE_DB_PASSWORD="sifre#icinde-ozel"
#
# Komutu her zaman bu klasorde calistir (pubspec.yaml'in oldugu yer):
#   cd .../mobile-dashboard && supabase db push

SUPABASE_DB_PASSWORD=
